{
  "manifest_version": 3,
  "name": "Video WebM Compressor",
  "description": "Batch convert uploaded videos to WebM using VP9, Opus, 600px width, and capped 30fps.",
  "version": "2.0.4",
  "permissions": [
    "downloads",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Video WebM Compressor"
  },
  "side_panel": {
    "default_path": "workspace.html"
  },
  "options_page": "workspace.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
  }
}
