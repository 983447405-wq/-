{
  "manifest_version": 3,
  "name": "Video WebM/WebP Compressor",
  "description": "Batch convert uploaded videos to compressed WebM or animated WebP files.",
  "version": "1.8.0",
  "permissions": [
    "downloads",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Video WebM/WebP Compressor"
  },
  "side_panel": {
    "default_path": "workspace.html"
  },
  "options_page": "workspace.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
  }
}
